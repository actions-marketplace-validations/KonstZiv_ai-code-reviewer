# AI Code Reviewer Configuration
# Copy this file to .env and fill in your values
#
# All variables support AI_REVIEWER_ prefix (preferred) or legacy names.
# See action.yml for GitHub Actions input mapping.

# =============================================================================
# Required: LLM Provider
# =============================================================================

# Google Gemini API key (required)
# Get key at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Gemini model (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_MODEL_FALLBACK=gemini-3-flash-preview

# =============================================================================
# Git Platform (one required)
# =============================================================================

# GitHub — https://github.com/settings/tokens (scopes: repo, write:discussion)
# GITHUB_TOKEN=

# GitLab — https://gitlab.com/-/profile/personal_access_tokens (scopes: api)
# GITLAB_TOKEN=
# GITLAB_URL=https://gitlab.com

# =============================================================================
# Review Settings
# =============================================================================

# Response language (ISO 639 code: en, uk, de, es, etc.)
# LANGUAGE=en

# Language mode: adaptive (detect from PR context) or fixed
# LANGUAGE_MODE=adaptive

# Max MR comment chars in AI prompt (0 to disable)
# REVIEW_MAX_COMMENT_CHARS=3000

# Include bot comments in AI prompt
# REVIEW_INCLUDE_BOT_COMMENTS=true

# Post inline comments on specific lines
# REVIEW_POST_INLINE_COMMENTS=true

# Group comments into threaded dialogues
# REVIEW_ENABLE_DIALOGUE=true

# =============================================================================
# Discovery
# =============================================================================

# Enable project discovery before review
# DISCOVERY_ENABLED=true

# Always post discovery comment (default: only on gaps)
# DISCOVERY_VERBOSE=false

# =============================================================================
# General
# =============================================================================

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
# LOG_LEVEL=INFO

# API request timeout in seconds
# API_TIMEOUT=60
